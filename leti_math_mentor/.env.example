# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Postgres / Supabase (asyncpg DSN) ---
# Supabase transaction pooler (port 6543) bo'lsa statement_cache_size=0 kod ichida qo'yilgan.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leti_ai_mentor

# --- Redis (ixtiyoriy). Bo'sh bo'lsa suhbat konteksti RAM'da saqlanadi (fallback). ---
REDIS_URL=

# --- Modellar (ixtiyoriy) ---
MODEL=claude-sonnet-4-6
HARD_MODEL=claude-opus-4-8
MAX_TOKENS=4096

# --- Sozlamalar (ixtiyoriy) ---
HISTORY_LIMIT=20
SESSION_TTL=3600
RATE_LIMIT_PER_MIN=15
ADMIN_USERNAME=mrleti
