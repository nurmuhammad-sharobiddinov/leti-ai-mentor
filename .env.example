# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Postgres (asyncpg DSN) ---
# misol: postgresql://user:password@host:5432/leti_ai_mentor
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leti_ai_mentor

# --- LLM modellari (ixtiyoriy, default qiymatlar mavjud) ---
EXPLAINER_MODEL=claude-opus-4-8
TEST_MODEL=claude-sonnet-4-6
ANALYSIS_MODEL=claude-sonnet-4-6

# --- Sozlamalar ---
MAX_TOKENS=4096
HISTORY_LIMIT=50
QUESTIONS_PER_TEST=5
ADMIN_USERNAME=mrleti
AUTO_MIGRATE=true
